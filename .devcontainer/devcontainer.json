{
  "name": "TripCostPro",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python"
      }
    }
  },
  "onCreateCommand": "curl -LsSf https://astral.sh/uv/install.sh | sh",
  "updateContentCommand": "~/.local/bin/uv sync",
  "forwardPorts": [8501],
  "postStartCommand": "echo 'To start Streamlit, run: ~/.local/bin/uv run streamlit run src/dashboarding/main.py'"
}